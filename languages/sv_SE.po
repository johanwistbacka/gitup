#: rg-git-updater.php:495
msgid "RG Git Updater – GitHub token is no longer working"
msgstr "RG Git Updater – GitHub-token fungerar inte längre."

#: rg-git-updater.php:498
msgid "Your GitHub token appears to be invalid or has expired."
msgstr "Din GitHub-token verkar vara felaktig eller har gått ut."

#: rg-git-updater.php:499
msgid "Action: Go to Tools → GitHub Updates and update the token."
msgstr ""
"Lösning: Gå till verktyg > GitHub Updates och uppdatera till en aktuell "
"token."

#: rg-git-updater.php:500
msgid ""
"Tip: Also verify the scopes (e.g. repo) if you need access to private "
"repositories."
msgstr ""
"Tips: Kontrollera även rättigheterna (t.ex. repo) om du behöver åtkomst "
"till privata repositorier."

#: rg-git-updater.php:501
msgid "Last checked:"
msgstr "Senast kontrollerad: "

#: rg-git-updater.php:502
msgid "Error at URL:"
msgstr "Fel vid URL:"

#: rg-git-updater.php:558
msgid "Could not create temporary file."
msgstr "Kan inte skapa temporär fil"

#: rg-git-updater.php:580
#, php-format
msgid ""
"GitHub did not return a ZIP (Content-Type: %s). Check token/access and the "
"release tag."
msgstr ""
"GitHub returnerade inte en ZIP (Content-Type: %s). Kontrollera token/"
"åtkomst och release-taggen."

#: rg-git-updater.php:586
#, php-format
msgid "GitHub download failed (HTTP %s)."
msgstr "GitHib nedladdning misslyckades (HTTP %s)"

#: rg-git-updater.php:813
msgid "RG Git Updater: Your GitHub token appears invalid or has expired."
msgstr ""
"RG Git Updater: Din Git Hub-token verkar vara felaktig eller har gått ut."

