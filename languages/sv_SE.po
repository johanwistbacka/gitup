#. Plugin Name of the plugin
#: index.php
msgid "Rätt Grafiska Git Updater"
msgstr "RG GitHub Uppdaterare"

#. Plugin URI of the plugin
#: index.php
msgid "https://github.com/Ratt-Grafiska/rg-git-updater"
msgstr "https://github.com/Ratt-Grafiska/rg-git-updater"

#. Description of the plugin
#: index.php
msgid "Handles automatic updates for Ratt Grafiska's plugins via GitHub."
msgstr ""
"Handhar automatiska förnyelser för Rätt Grafiskas tillägg och teman via det "
"hedersamma GitHub."

#. Author of the plugin
#: index.php
msgid "Ratt Grafiska"
msgstr "Rätt Grafiska AB"

