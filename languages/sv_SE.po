msgid "RG Git Updater – GitHub token is no longer working"
msgstr "RG Git Updater – GitHub-token fungerar inte längre"

#: rg-git-updater.php:503
#, php-format
msgid "Your GitHub token on \"%s\" appears to be invalid or has expired."
msgstr "Din GitHub-token på \"%s\" verkar vara ogiltig eller har löpt ut."

#: rg-git-updater.php:507
#, php-format
msgid ""
"Action: <a href=\"%s\">Go to Tools → GitHub Updates and update the token.</a>"
msgstr ""
"Lösning: <a href=\"%s\">Gå till verktyg > GitHub Updates och uppdatera till "
"en aktuell token.</a>"

#: rg-git-updater.php:510
msgid ""
"Tip: Also verify the scopes (e.g. repo) if you need access to private "
"repositories."
msgstr ""
"Tips: Kontrollera även rättigheterna (t.ex. repo) om du behöver åtkomst till "
"privata repositorier."

